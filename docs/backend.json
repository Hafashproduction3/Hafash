
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Extended user data for photographers.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "studioName": { "type": "string" },
        "photographerName": { "type": "string" },
        "whatsappNumber": { "type": "string" },
        "planId": { "type": "string", "enum": ["starter", "pro", "business"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "studioName"]
    },
    "Gallery": {
      "title": "Gallery",
      "description": "A collection of photos for a specific client event.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "clientName": { "type": "string" },
        "date": { "type": "string" },
        "category": { "type": "string" },
        "coverImage": { "type": "string" },
        "items": { "type": "array" },
        "isLocked": { "type": "boolean" },
        "isPublic": { "type": "boolean" },
        "isPaid": { "type": "boolean" },
        "viewCount": { "type": "number" },
        "userId": { "type": "string" },
        "isPasswordProtected": { "type": "boolean", "description": "Whether the gallery requires a password to view." },
        "hashedPassword": { "type": "string", "description": "SHA-256 hash of the gallery password." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "userId"]
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles for photographers."
    },
    "/galleries/{galleryId}": {
      "schema": "Gallery",
      "description": "Event galleries and assets."
    }
  }
}
