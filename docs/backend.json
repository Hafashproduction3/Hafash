
{
  "entities": {
    "MediaItem": {
      "title": "MediaItem",
      "description": "A production-grade image or video asset stored in Cloudflare R2 or Demo storage",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "deliveryProvider": { 
          "type": "string", 
          "enum": ["demo", "r2"],
          "description": "Specifies if the asset is a mock picsum link or a real R2 asset"
        },
        "fileName": { "type": "string" },
        "mimeType": { "type": "string" },
        "sizeBytes": { "type": "number" },
        "width": { "type": "number" },
        "height": { "type": "number" },
        "storagePath": { "type": "string", "description": "R2 Key for the original master file" },
        "previewPath": { "type": "string", "description": "R2 Key for the 2000px optimized version" },
        "thumbnailPath": { "type": "string", "description": "R2 Key for the 400px grid version" },
        "url": { "type": "string", "description": "Direct URL (used primarily for demo mode)" },
        "isFavorite": { "type": "boolean" },
        "uploadedAt": { "type": "string", "format": "date-time" },
        "aiLabels": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "Tags generated by AI for searchability (e.g. 'Cake', 'Bride')"
        },
        "faceIds": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "IDs of recognized faces for AI-driven face search"
        }
      },
      "required": ["id", "deliveryProvider", "isFavorite"]
    },
    "EventGallery": {
      "title": "EventGallery",
      "description": "A collection of media for a specific event",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "clientName": { "type": "string" },
        "date": { "type": "string" },
        "category": { "type": "string" },
        "coverImage": { "type": "string" },
        "deliveryProvider": { 
          "type": "string", 
          "enum": ["demo", "r2"],
          "description": "Determines if the gallery uses legacy 'items' array or the production 'media' subcollection"
        },
        "mediaCount": { "type": "number" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/entities/MediaItem" },
          "description": "Used only when deliveryProvider is 'demo'"
        },
        "isLocked": { "type": "boolean" },
        "isPublic": { "type": "boolean" },
        "isPaid": { "type": "boolean" },
        "viewCount": { "type": "number" },
        "userId": { "type": "string" },
        "albumStatus": { 
          "type": "string", 
          "enum": ["New Selection", "Album Package Generated", "Shared with Album Designer", "Completed"] 
        },
        "albumLinkEnabled": { "type": "boolean" },
        "albumLinkToken": { "type": "string" }
      },
      "required": ["id", "slug", "title", "userId", "deliveryProvider"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Photographer studio settings",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "studioName": { "type": "string" },
        "photographerName": { "type": "string" },
        "whatsappNumber": { "type": "string" },
        "studioLogo": { "type": "string" },
        "planId": { "type": "string", "enum": ["starter", "pro", "business"] }
      },
      "required": ["userId", "studioName"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/galleries/{galleryId}": {
      "schema": "#/entities/EventGallery",
      "description": "Gallery metadata. Publicly readable if isPublic is true."
    },
    "/galleries/{galleryId}/media/{mediaId}": {
      "schema": "#/entities/MediaItem",
      "description": "Individual assets in a production gallery. Inherits visibility from parent gallery."
    },
    "/users/{userId}": {
      "schema": "#/entities/UserProfile",
      "description": "Private photographer profiles."
    }
  }
}
