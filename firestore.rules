rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User Profile Rules
    match /users/{userId} {
      allow get, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Gallery Security Rules
    match /galleries/{galleryId} {
      // allow list: allow visitors to query public galleries (required for slug resolution)
      // or owners to query their own collection.
      allow list: if (resource.data.isPublic == true) || (request.auth != null && request.auth.uid == resource.data.userId);
      
      // allow get: allow visitors to view public galleries by ID
      // or owners to view their own private galleries.
      allow get: if (resource.data.isPublic == true) || (request.auth != null && request.auth.uid == resource.data.userId);
      
      // allow create/update/delete: strictly restricted to authenticated owners.
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // Communication Templates
    match /communication_templates/{templateId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
    }
  }
}