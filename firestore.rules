rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Galleries: Public read if isPublic is true (defaults to true if missing), otherwise requires owner authentication
    match /galleries/{galleryId} {
      allow read: if (resource != null && resource.data.get('isPublic', true) == true) || (request.auth != null && request.auth.uid == resource.data.userId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // User Profiles: Strictly private, only accessible by the authenticated owner
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Default: Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}