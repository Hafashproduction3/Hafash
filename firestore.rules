rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check gallery ownership
    function isGalleryOwner(galleryId) {
      return request.auth != null && request.auth.uid == get(/databases/$(database)/documents/galleries/$(galleryId)).data.userId;
    }

    // Helper to check album designer access
    function isAlbumDesigner(galleryData) {
      return galleryData.albumLinkEnabled == true && galleryData.albumLinkToken != "";
    }

    // Galleries: Metadata and Legacy items
    match /galleries/{galleryId} {
      allow read: if (resource.data.isPublic == true) 
                  || (request.auth != null && request.auth.uid == resource.data.userId)
                  || isAlbumDesigner(resource.data);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      
      // Production Media Subcollection
      match /media/{mediaId} {
        // Inherit read rules from parent gallery
        allow read: if get(/databases/$(database)/documents/galleries/$(galleryId)).data.isPublic == true 
                    || request.auth != null && request.auth.uid == get(/databases/$(database)/documents/galleries/$(galleryId)).data.userId
                    || isAlbumDesigner(get(/databases/$(database)/documents/galleries/$(galleryId)).data);
        
        // Only owner can write to the media collection
        allow write: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/galleries/$(galleryId)).data.userId;
      }
    }

    // User Profiles: Strictly private
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
