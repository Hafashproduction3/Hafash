# Firebase Admin SDK Credentials
# Obtain these from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Key-With-Newlines-Escaped\n-----END PRIVATE KEY-----"

# Public Firebase Configuration (Used by Client SDK)
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
